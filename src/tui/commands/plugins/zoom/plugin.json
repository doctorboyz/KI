{
  "name": "zoom",
  "version": "1.0.0",
  "entry": "./index.ts",
  "sdk": "^1.0.0",
  "description": "Toggle tmux pane zoom (full-screen) — wraps resize-pane -Z.",
  "cli": {
    "command": "zoom",
    "help": "maw zoom <target> [--pane N]",
    "flags": {
      "--pane": "number"
    }
  },
  "api": {
    "path": "/api/zoom",
    "methods": [
      "POST"
    ]
  },
  "weight": 10
}
