    "hono": "^4.12.5",
    "ink": "^5.0.0",
    "ink-text-input": "^5.0.1",
    "mqtt": "^5.15.1",
    "react": "^18.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.0",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.5.0"
  }
