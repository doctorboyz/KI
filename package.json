{
  "name": "ki",
  "version": "1.0.0",
  "description": "KI — Kappa Interface. Multi-agent workflow with keyboard-first TUI.",
  "type": "module",
  "license": "BUSL-1.1",
  "repository": "doctorboyz/KI",
  "bin": {
    "ki": "./src/cli.ts"
  },
